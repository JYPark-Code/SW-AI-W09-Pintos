+
+static void
+remove_with_lock(struct lock *lock) {
+
+	struct thread *cur = thread_current();
+	struct list_elem *e;
+
+	/* 1. 현재 thread의 donations 리스트 순회 */
+	for(e = list_begin(&cur->donations); 
+		e != list_end(&cur->donations);
